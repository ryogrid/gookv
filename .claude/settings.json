{
  "env": {
    "CLAUDE_CODE_AGENT_ID": "gookv-primary",
    "CLAUDE_CODE_AGENT_NAME": "gookv-dev",
    "CLAUDE_CODE_MAX_AGENT_ITERATIONS": "50"
  },
  "permissions": {
    "allow": [
      "Bash(git submodule:*)"
    ],
    "additionalDirectories": [
      "/home/ryo/.claude/homunculus"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/ryo/work/gookv/.claude/skills/continuous-learning-v2/hooks/observe.sh pre",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/ryo/work/gookv/.claude/skills/continuous-learning-v2/hooks/observe.sh post",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
